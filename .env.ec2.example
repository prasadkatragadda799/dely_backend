# ─── Required ────────────────────────────────────────────────────────────────

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-strong-secret

# Full PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@host:5432/dely_db
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/dely_db

# ─── AWS RDS Alternative (use instead of DATABASE_URL) ───────────────────────
# Fetches DB credentials dynamically from AWS Secrets Manager on boot.
# Leave DATABASE_URL blank when using these.
# DB_SECRET_ID=arn:aws:secretsmanager:ap-south-2:123456789012:secret:rds!db-xxxxxx
# AWS_REGION=ap-south-2
# DB_HOST=database-1.example.ap-south-2.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=postgres
# DB_ENGINE=postgresql
# DB_QUERY=sslmode=require

# ─── Environment ─────────────────────────────────────────────────────────────

ENVIRONMENT=production
DEBUG=false

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://app.delycart.in,https://admin.delycart.in

# ─── Runtime Tuning ──────────────────────────────────────────────────────────

PORT=8000
WEB_CONCURRENCY=3
GUNICORN_TIMEOUT=120

# Set to true to auto-run migrations on boot
RUN_MIGRATIONS=true

# ─── First Admin (optional, created on boot if set) ──────────────────────────

ADMIN_EMAIL=admin@dely.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin
ADMIN_ROLE=super_admin

# ─── Integrations (optional) ─────────────────────────────────────────────────

GOOGLE_MAPS_API_KEY=AIzaSyA4G30lGnS7nEbDd1xX4_L_wDm6K4kZuGg
TWO_FACTOR_API_KEY=

# Test phone that bypasses real OTP (for Play Store review accounts)
PLAYSTORE_TEST_PHONE=7997919145
PLAYSTORE_TEST_OTP=654321
PLAYSTORE_TEST_REQUEST_ID=PLAYSTORE-OTP-SESSION

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@dely.backend
