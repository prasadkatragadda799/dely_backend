ENVIRONMENT=production
DEBUG=false

# Set a strong random value:
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-strong-secret

# Example (PostgreSQL):
# DATABASE_URL=postgresql://user:password@db-host:5432/dely_db
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/dely_db
# Or, fetch the password dynamically from AWS Secrets Manager on boot.
# Leave DATABASE_URL blank when using DB_SECRET_ID.
# DB_SECRET_ID=arn:aws:secretsmanager:ap-south-2:123456789012:secret:rds!db-xxxxxx
# AWS_REGION=ap-south-2
# DB_HOST=database-1.example.ap-south-2.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=postgres
# DB_ENGINE=postgresql
# DB_QUERY=sslmode=require

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://app.delycart.in,https://admin.delycart.in

# Runtime tuning
PORT=8000
WEB_CONCURRENCY=3
GUNICORN_TIMEOUT=120
RUN_MIGRATIONS=true

# Optional: create first admin on boot
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
ADMIN_ROLE=super_admin

# Optional integrations
GOOGLE_MAPS_API_KEY=
TWO_FACTOR_API_KEY=
# This phone skips 2Factor in every environment (set OTP via PLAYSTORE_TEST_OTP).
PLAYSTORE_TEST_PHONE=7997919145
PLAYSTORE_TEST_OTP=654321
PLAYSTORE_TEST_REQUEST_ID=PLAYSTORE-OTP-SESSION
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@dely.backend
